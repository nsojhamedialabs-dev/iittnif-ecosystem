# ui

The six reusable modules from PDR Section 08, plus components added for
the beyond-brief commitments. One component, re-themed per page via the
design-system tokens — not eight one-off builds.

- `Hero/` — full-bleed statement + 2 CTAs
- `Pillars/` — 3–6 card grid, hover reveal
- `Pipeline/` — animated horizontal flow (Research → Impact, re-scoped per page)
- `Portfolio/` — filterable card grid
- `Stories/` — photo + narrative + outcome
- `EngageCTA/` — stakeholder card router (routes into VIKAS)
- `Glossary/` — hover-tooltip inline glossary (PDR beyond-brief: GNSS, GeoAI, etc.)
- `LanguageToggle/` — EN/HI toggle, default-on bilingual layer
- `ImpactCounter/` — live counter component, consumes cms-client — fixes Dronagiri's zero-stat problem
- `Map/` — interactive India map (Mapbox/Leaflet per PDR Section 07), used in Dronagiri /pilots and iittnif-web SPIN Labs section
</file>

<file path="packages/ui/src/Hero/Hero.tsx">
// MOBILE-FIRST: see /MOBILE_FIRST.md — this component/page is designed
// and coded for 360px first. Unprefixed Tailwind classes = mobile
// layout; sm:/md:/lg:/xl: add desktop enhancements, they never carry
// the primary layout logic.
'use client'

import type { SpineStage } from '@iittnif/design-system'
import { motion, useReducedMotion, type Variants } from 'framer-motion'

const spineBg: Record<SpineStage, string> = {
  research: 'bg-spine-research',
  mandate: 'bg-spine-mandate',
  architecture: 'bg-spine-architecture',
  delivery: 'bg-spine-delivery',
  nationalImpact: 'bg-spine-impact',
}

export interface HeroProps {
  eyebrow?: string
  title: string
  subtitle?: string
  primaryCta?: { label: string; href: string }
  secondaryCta?: { label: string; href: string }
  stage?: SpineStage
  children?: React.ReactNode
}

export function Hero({
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  stage = 'research',
  children,
}: HeroProps) {
  const shouldReduceMotion = useReducedMotion()

  const container: Variants = {
    hidden: {},
    show: {
      transition: { staggerChildren: shouldReduceMotion ? 0 : 0.08 },
    },
  }
  const item: Variants = {
    hidden: shouldReduceMotion ? {} : { opacity: 0, y: 16 },
    show: {
      opacity: 1,
      y: 0,
      transition: { duration: 0.4, ease: 'easeOut' },
    },
  }

  return (
    <motion.section
      className="relative overflow-hidden py-16 md:py-24"
      variants={container}
      initial="hidden"
      animate="show"
    >
      <div className={`absolute left-0 top-0 h-1 w-24 ${spineBg[stage]}`} aria-hidden />
      {eyebrow && (
        <motion.p
          variants={item}
          className="mb-3 font-mono text-small uppercase tracking-wide text-neutral-text-secondary"
        >
          {eyebrow}
        </motion.p>
      )}
      <motion.h1
        variants={item}
        className="max-w-4xl text-hero font-semibold leading-tight text-neutral-text"
      >
        {title}
      </motion.h1>
      {subtitle && (
        <motion.p variants={item} className="mt-6 max-w-2xl text-bodyLg text-neutral-text-secondary">
          {subtitle}
        </motion.p>
      )}
      <motion.div variants={item} className="mt-8 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
        {primaryCta && (
          <a
            href={primaryCta.href}
            className={`w-full rounded-md px-6 py-3 text-center font-medium text-white transition-transform hover:scale-[1.02] sm:w-auto ${spineBg[stage]}`}
          >
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            className="w-full rounded-md border border-neutral-border px-6 py-3 text-center font-medium text-neutral-text transition-transform hover:scale-[1.02] sm:w-auto"
          >
            {secondaryCta.label}
          </a>
        )}
      </motion.div>
      {children && (
        <motion.div variants={item} className="mt-12">
          {children}
        </motion.div>
      )}
    </motion.section>
  )
}
</file>

